{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Server=XXXXXX;Database=IndividualsDirectory;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "ImageStorage": {
    "BasePath": "uploads/individuals",
    "MaxBytes": 5242880,
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "image/gif",
      "image/webp"
    ]
  }
}
